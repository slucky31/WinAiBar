<UserControl
    x:Class="WinAIBar.Views.Controls.QuotaBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel Spacing="4" Padding="0,4">
        <Grid>
            <TextBlock x:Name="LabelText" FontSize="12" VerticalAlignment="Center" />
            <TextBlock x:Name="RightText"
                       FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center" />
        </Grid>
        <ProgressBar x:Name="Bar" Maximum="1.0" Height="8" CornerRadius="4" />
    </StackPanel>
</UserControl>
