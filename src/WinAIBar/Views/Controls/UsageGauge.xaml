<UserControl
    x:Class="WinAIBar.Views.Controls.UsageGauge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel HorizontalAlignment="Center" Spacing="4" Padding="4,8">
        <Grid Width="180" Height="180">
            <lvc:PieChart x:Name="GaugeChart"
                          InitialRotation="-135"
                          MaxAngle="270"
                          Width="180" Height="180" />
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="2">
                <TextBlock x:Name="PercentText"
                           FontSize="32" FontWeight="Bold"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="LabelText"
                           HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="110" />
                <TextBlock x:Name="SubtitleText"
                           HorizontalAlignment="Center" FontSize="11"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="110"
                           Visibility="Collapsed" />
                <TextBlock x:Name="ResetTextBlock"
                           HorizontalAlignment="Center" FontSize="10"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="110"
                           Visibility="Collapsed" />
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
