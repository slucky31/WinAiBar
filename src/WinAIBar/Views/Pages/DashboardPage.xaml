<Page
    x:Class="WinAIBar.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinAIBar.Views.Controls"
    xmlns:vm="using:WinAIBar.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top bar: Refresh + timestamp -->
        <Border Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Padding="16,10">
            <Grid>
                <TextBlock Text="Dashboard" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="12">
                    <TextBlock Text="{x:Bind ViewModel.LastRefreshedText, Mode=OneWay}"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <Button Content="Refresh now"
                            Command="{x:Bind ViewModel.RefreshCommand}"
                            Style="{ThemeResource AccentButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Provider columns -->
        <ScrollViewer Grid.Row="1">
            <Grid Padding="16" ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Claude column -->
                <StackPanel Grid.Column="0" Spacing="8">
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="Claude" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Border HorizontalAlignment="Right" CornerRadius="4"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                Padding="8,3">
                            <TextBlock Text="{x:Bind ViewModel.ClaudeStatusText, Mode=OneWay}"
                                       FontSize="11" />
                        </Border>
                    </Grid>

                    <!-- Major quotas: 3 UsageGauges -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.ClaudeMajorQuotas, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="110" MinColumnSpacing="8"
                                               MinRowSpacing="8" ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:QuotaViewModel">
                                <controls:UsageGauge
                                    Label="{x:Bind Label}"
                                    Value="{x:Bind Value}"
                                    ResetsAt="{x:Bind ResetsAt}"
                                    Subtitle="{x:Bind Subtitle}" />
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Other quotas: compact list -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.ClaudeOtherQuotas, Mode=OneWay}"
                                   Margin="0,4,0,0">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:QuotaViewModel">
                                <controls:QuotaBar
                                    Label="{x:Bind Label}"
                                    Value="{x:Bind Value}"
                                    ResetText="{x:Bind ResetText}" />
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Copilot column -->
                <StackPanel Grid.Column="1" Spacing="8">
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="Copilot" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Border HorizontalAlignment="Right" CornerRadius="4"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                Padding="8,3">
                            <TextBlock Text="{x:Bind ViewModel.CopilotStatusText, Mode=OneWay}"
                                       FontSize="11" />
                        </Border>
                    </Grid>

                    <!-- Major quotas: 2 UsageGauges -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.CopilotMajorQuotas, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="110" MinColumnSpacing="8"
                                               MinRowSpacing="8" ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:QuotaViewModel">
                                <controls:UsageGauge
                                    Label="{x:Bind Label}"
                                    Value="{x:Bind Value}"
                                    ResetsAt="{x:Bind ResetsAt}"
                                    Subtitle="{x:Bind Subtitle}" />
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Empty state when no Copilot token -->
                    <TextBlock Visibility="{x:Bind ViewModel.CopilotEmptyStateVisibility, Mode=OneWay}"
                               Text="Sign in to GitHub Copilot in Settings to see Copilot usage."
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
