<Window
    x:Class="WinAIBar.Views.Flyouts.TrayFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinAIBar.Views.Controls"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE8A1;" FontSize="18" />
                <TextBlock Text="WinAIBar" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
            <Button Content="&#x2699;" HorizontalAlignment="Right"
                    Command="{x:Bind ViewModel.OpenMainWindowCommand}"
                    ToolTipService.ToolTip="Open WinAIBar" />
        </Grid>

        <!-- Claude section -->
        <TextBlock Grid.Row="1" Text="Claude" FontSize="12" FontWeight="SemiBold"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,4" />
        <StackPanel Grid.Row="2" Spacing="2" Margin="0,0,0,8">
            <controls:QuotaBar
                Label="{x:Bind ViewModel.ClaudeSessionLabel, Mode=OneWay}"
                Value="{x:Bind ViewModel.ClaudeSessionValue, Mode=OneWay}"
                ResetText="{x:Bind ViewModel.ClaudeSessionResetText, Mode=OneWay}" />
            <controls:QuotaBar
                Label="{x:Bind ViewModel.ClaudeWeeklyLabel, Mode=OneWay}"
                Value="{x:Bind ViewModel.ClaudeWeeklyValue, Mode=OneWay}"
                ResetText="{x:Bind ViewModel.ClaudeWeeklyResetText, Mode=OneWay}" />
        </StackPanel>

        <!-- Copilot section -->
        <TextBlock Grid.Row="3" Text="Copilot" FontSize="12" FontWeight="SemiBold"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,4" />
        <StackPanel Grid.Row="4" Spacing="2" Margin="0,0,0,8">
            <controls:QuotaBar
                Label="{x:Bind ViewModel.CopilotPremiumLabel, Mode=OneWay}"
                Value="{x:Bind ViewModel.CopilotPremiumValue, Mode=OneWay}"
                ResetText="{x:Bind ViewModel.CopilotPremiumResetText, Mode=OneWay}" />
            <controls:QuotaBar
                Label="{x:Bind ViewModel.CopilotCreditsLabel, Mode=OneWay}"
                Value="{x:Bind ViewModel.CopilotCreditsValue, Mode=OneWay}"
                ResetText="{x:Bind ViewModel.CopilotCreditsResetText, Mode=OneWay}" />
        </StackPanel>

        <!-- Spacer -->
        <Grid Grid.Row="5" />

        <!-- Footer -->
        <Grid Grid.Row="6" Margin="0,8,0,0">
            <TextBlock Text="{x:Bind ViewModel.LastUpdateText, Mode=OneWay}"
                       FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center" />
            <Button Content="Refresh"
                    HorizontalAlignment="Right"
                    Command="{x:Bind ViewModel.RefreshCommand}"
                    Style="{ThemeResource AccentButtonStyle}" />
        </Grid>
    </Grid>
</Window>
